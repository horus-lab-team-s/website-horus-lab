# ─────────────────────────────────────────────────────────────
# Copiez ce fichier en `.env.local` (cp .env.example .env.local)
# puis renseignez vos valeurs. `.env.local` n'est jamais commité.
# ─────────────────────────────────────────────────────────────

# ── Brevo — e-mail (newsletter + contact) ──
# Sans BREVO_API_KEY, les soumissions sont stockées dans .data/ (dev).
# Clé API : https://app.brevo.com > SMTP & API > API Keys
BREVO_API_KEY=
# ID de la liste de contacts pour la newsletter (Brevo > Contacts > Listes)
BREVO_NEWSLETTER_LIST_ID=
# Adresse e-mail qui reçoit les messages du formulaire de contact
BREVO_CONTACT_TO=contact@horus-lab.com
# Expéditeur (doit être un expéditeur/domaine validé dans Brevo)
BREVO_SENDER_EMAIL=noreply@horus-lab.com
BREVO_SENDER_NAME=Horus-Lab

# ── URL canonique du site (SEO/sitemap/JSON-LD) ──
NEXT_PUBLIC_SITE_URL=https://horus-lab.com

# ── Horus AI — assistant (modèle gratuit Groq) ──
# Sans clé, l'assistant répond via une FAQ intégrée.
# Clé gratuite : https://console.groq.com/keys
GROQ_API_KEY=
# Modèle (optionnel) ; défaut : llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile
