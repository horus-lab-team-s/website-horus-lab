# Variables lues par docker-compose. Copiez en `.env` et adaptez.
# (Le fichier `.env` réel n'est jamais commité.)

# --- PostgreSQL ---
POSTGRES_DB=horuslab
POSTGRES_USER=horus
POSTGRES_PASSWORD=change-me-strong-password

# --- Django ---
DJANGO_SECRET_KEY=change-me-long-random-string
# 0 = production (recommandé en docker), 1 = développement
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# En prod, ex. https://api.horus-lab.com
CSRF_TRUSTED_ORIGINS=

# --- Compte admin créé automatiquement au 1er démarrage (optionnel) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=contact@horus-lab.com
DJANGO_SUPERUSER_PASSWORD=

# --- Frontend (Next.js) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Clés serveur du frontend (assistant Horus AI + e-mails Brevo)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
BREVO_API_KEY=
BREVO_NEWSLETTER_LIST_ID=
BREVO_CONTACT_TO=contact@horus-lab.com
BREVO_SENDER_EMAIL=noreply@horus-lab.com
BREVO_SENDER_NAME=Horus-Lab
