# ─────────────────────────────────────────────────────────────
# Brevo — intégration e-mail (newsletter + contact)
# Copiez ce fichier en `.env.local` et renseignez vos valeurs.
# Sans BREVO_API_KEY, les soumissions sont stockées dans .data/ (dev).
# ─────────────────────────────────────────────────────────────

# Clé API Brevo : https://app.brevo.com > SMTP & API > API Keys
BREVO_API_KEY=

# ID de la liste de contacts qui reçoit les inscriptions newsletter
# (Brevo > Contacts > Listes). Laissez vide pour ne pas cibler de liste.
BREVO_NEWSLETTER_LIST_ID=

# Adresse e-mail qui reçoit les messages du formulaire de contact
BREVO_CONTACT_TO=contact@horus-lab.com

# Expéditeur des e-mails (doit être un expéditeur/domaine validé dans Brevo)
BREVO_SENDER_EMAIL=noreply@horus-lab.com
BREVO_SENDER_NAME=Horus-Lab

# URL canonique du site (SEO/sitemap/JSON-LD). En prod Vercel, mettez votre
# domaine final, ex. https://horus-lab.com
NEXT_PUBLIC_SITE_URL=https://horus-lab.com

# ─────────────────────────────────────────────────────────────
# Horus AI — assistant conversationnel (modèle gratuit Groq)
# Sans clé, l'assistant répond via une FAQ intégrée (services, contact…).
# Clé gratuite : https://console.groq.com/keys
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=
# Modèle (optionnel) ; défaut : llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile
