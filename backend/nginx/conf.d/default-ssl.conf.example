# PHASE 2 — HTTPS. À activer APRÈS avoir obtenu le certificat (étape certbot).
#
#   mv conf.d/default.conf            conf.d/default.conf.http-only
#   cp conf.d/default-ssl.conf.example conf.d/default.conf
#   docker compose exec nginx nginx -s reload
#
# (Les chemins ssl_certificate pointent vers le volume certbot-conf.)

# HTTP : ne sert que le challenge ACME, redirige tout le reste vers HTTPS.
server {
    listen 80;
    listen [::]:80;
    server_name backend.website.horus-lab.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS : termine TLS et proxifie l'API.
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name backend.website.horus-lab.com;

    ssl_certificate     /etc/letsencrypt/live/backend.website.horus-lab.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/backend.website.horus-lab.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # HSTS (force HTTPS côté navigateur pendant 6 mois).
    add_header Strict-Transport-Security "max-age=15768000" always;

    location /static/ {
        alias /var/www/static/;
        access_log off;
        expires 30d;
    }

    location /media/ {
        alias /var/www/media/;
        access_log off;
        expires 30d;
    }

    location / {
        proxy_pass http://web:8000;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 25m;
    }
}
