# Copiez en `.env` et adaptez. Ne committez jamais `.env`.

# Clé secrète Django (générez-en une en prod)
DJANGO_SECRET_KEY=dev-secret-change-me
# 1 = développement, 0 = production
DJANGO_DEBUG=1
# Hôtes autorisés (séparés par des virgules) — ajoutez votre domaine en prod
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Origines autorisées à appeler l'API (le frontend Next.js)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Domaines de confiance CSRF en prod (admin via HTTPS), ex. https://api.horus-lab.com
CSRF_TRUSTED_ORIGINS=

# Base de données. Vide = SQLite local. En prod, collez l'URL PostgreSQL
# (Neon/Supabase/serveur), ex :
# DATABASE_URL=postgresql://user:password@host:5432/horuslab?sslmode=require
DATABASE_URL=

# (Optionnel) Brevo, si on déplace l'envoi d'e-mails côté backend plus tard
BREVO_API_KEY=
BREVO_NEWSLETTER_LIST_ID=
