# ─────────────────────────────────────────────────────────────
# Backend Horus-Lab — variables d'environnement
# Copiez en `.env` (jamais commité) et renseignez vos valeurs.
# ─────────────────────────────────────────────────────────────

# --- Django ---
# Clé secrète : en prod, générez-en une longue et aléatoire :
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=dev-secret-change-me
# 1 = développement, 0 = production
DJANGO_DEBUG=1
# Hôtes autorisés (virgules) — en prod : backend.website.horus-lab.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Sécurité / domaines de confiance ---
# Origine(s) du frontend autorisée(s) à appeler l'API (CORS).
# Prod : https://horus-lab.com,https://www.horus-lab.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Origine de confiance pour l'admin en HTTPS (CSRF).
# Prod : https://backend.website.horus-lab.com
CSRF_TRUSTED_ORIGINS=
# Laissez 0 : en prod, c'est nginx qui force la redirection http→https.
SECURE_SSL_REDIRECT=0

# --- Base de données ---
# DEV : laissez vide → SQLite local.
# PROD AVEC DOCKER : laissez vide aussi → docker-compose construit DATABASE_URL
#   automatiquement à partir des POSTGRES_* ci-dessous.
# PROD SANS DOCKER (Neon/Supabase) : collez l'URL ici, ex :
#   DATABASE_URL=postgresql://user:password@host:5432/horuslab?sslmode=require
DATABASE_URL=

# --- PostgreSQL (service db du docker-compose, prod) ---
POSTGRES_DB=horuslab
POSTGRES_USER=horuslab
POSTGRES_PASSWORD=change-me-strong-db-password

# --- Compte admin créé automatiquement au 1er démarrage (entrypoint Docker) ---
# Laissez vide pour le créer manuellement via `createsuperuser`.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=contact@horus-lab.com
DJANGO_SUPERUSER_PASSWORD=change-me-strong-admin-password

# --- Seed des contenus par défaut ---
# 1 = insère/actualise les contenus de démo au démarrage. À mettre à 1 pour
# le PREMIER déploiement uniquement, puis repasser à 0 : sinon chaque
# redéploiement ÉCRASE les contenus que vous avez édités dans l'admin.
RUN_SEED=0
