# ─────────────────────────────────────────────────────────────────────────────
# Horus-Lab — variables du STACK DE PRODUCTION (VPS Contabo).
# Copier en `.env` À CÔTÉ de docker-compose.prod.yml, puis `chmod 600 .env`.
# NE JAMAIS committer le .env rempli. (Ce .example, lui, peut être committé.)
# ⚠️ Pas de commentaire en fin de ligne (dotenv l'inclurait dans la valeur).
# ─────────────────────────────────────────────────────────────────────────────

# ===== Django — cœur =========================================================
# Générer : python3 -c "import secrets;print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=
# En production : 0 (obligatoire ; avec 1, le site expose les erreurs).
DJANGO_DEBUG=0
# Hôte(s) autorisé(s) pour l'API/admin. Le sous-domaine backend UNIQUEMENT.
DJANGO_ALLOWED_HOSTS=api.horus-lab.com
# Origines autorisées à appeler l'API depuis le navigateur (le site public).
CORS_ALLOWED_ORIGINS=https://horus-lab.com,https://www.horus-lab.com
# Origines de confiance pour les formulaires admin en HTTPS.
CSRF_TRUSTED_ORIGINS=https://api.horus-lab.com
# Forcer la redirection HTTPS côté Django (laisser 0 : Nginx s'en charge déjà).
SECURE_SSL_REDIRECT=0

# ===== PostgreSQL ============================================================
# Générer un mot de passe : openssl rand -hex 24
POSTGRES_DB=horuslab
POSTGRES_USER=horuslab
POSTGRES_PASSWORD=

# ===== Compte admin auto (créé au 1er démarrage par l'entrypoint) ============
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=contact@horus-lab.com
# Mot de passe fort ; À CHANGER après le 1er login (il est en clair ici).
DJANGO_SUPERUSER_PASSWORD=

# ===== Seed (contenus de démo) ===============================================
# 1 UNIQUEMENT pour le tout 1er déploiement (remplit hero/services/blog/équipe…).
# Repasser à 0 ensuite, sinon chaque redémarrage ÉCRASE vos contenus de l'admin.
RUN_SEED=1

# ===== Brevo — e-mails (newsletter + contact + candidatures + notifs) ========
# ⚠️ Le BACKEND en a besoin pour ses notifs (chat/candidatures) — pas seulement
# le frontend. Clé DÉDIÉE au site, compte horus8391 (xkeysib-...).
# ⚠️ Autoriser l'IP du VPS dans Brevo (Sécurité → IP autorisées), sinon 401.
BREVO_API_KEY=
BREVO_CONTACT_TO=contact@horus-lab.com
BREVO_SENDER_EMAIL=contact@horus-lab.com
BREVO_SENDER_NAME=Horus-Lab
# ID numérique de la liste newsletter (doit exister dans le compte horus8391).
BREVO_NEWSLETTER_LIST_ID=5
# Destinataire des notifs (repli sur BREVO_CONTACT_TO si vide).
CHAT_NOTIFY_EMAIL=contact@horus-lab.com
# Base d'URL mise dans le lien « Répondre dans l'admin » des e-mails de notif.
ADMIN_BASE_URL=https://api.horus-lab.com

# ===== Horus AI — assistant (Groq, gratuit) ==================================
# console.groq.com/keys. Sans clé : repli sur une FAQ intégrée (dégradé, pas cassé).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ===== Reverse proxy (conteneur existant) ====================================
# Nom du RÉSEAU Docker de ton proxy existant : `web` et `frontend` le rejoignent
# pour être joignables par nom (horus_web / horus_frontend). Trouve-le avec :
#   docker network ls
PROXY_NETWORK=
# Ports 127.0.0.1 (débogage local uniquement). Change-les si déjà pris.
BACKEND_PORT=8082
FRONTEND_PORT=8081

# ===== Frontend (Next.js) — lues par les routes /api/* ======================
# URL publique du site (SEO / sitemap / JSON-LD).
NEXT_PUBLIC_SITE_URL=https://horus-lab.com
# URL publique du backend (SSR + next/image). Doit rester le domaine public.
BACKEND_API_URL=https://api.horus-lab.com

# ===== Notifications Telegram — OPTIONNEL (laisser vide) =====================
# @BotFather /newbot -> token ; puis getUpdates -> chat.id. L'e-mail suffit.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Rollback (avancé) — épingler une image précise ========================
# Par défaut le stack tire :latest. Pour revenir en arrière, décommente et mets
# un tag `sha-xxxxxxx` (visible dans GHCR / l'onglet Actions), puis `up -d`.
# BACKEND_IMAGE=ghcr.io/horus-lab-team-s/horus-backend:sha-xxxxxxx
# FRONTEND_IMAGE=ghcr.io/horus-lab-team-s/horus-frontend:sha-xxxxxxx
